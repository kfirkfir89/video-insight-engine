# ================================================
# Video Insight Engine - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values
# ================================================
CLAUDE_PROJECT_DIR="/path/to/your/video-insight-engine"

# ------------------------------------------------
# General
# ------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# ------------------------------------------------
# MongoDB
# ------------------------------------------------
# Development (no auth)
MONGODB_URI=mongodb://localhost:27017/video-insight-engine

# Production (with auth)
# MONGO_ROOT_USER=admin
# MONGO_ROOT_PASS=change-this-password

# ------------------------------------------------
# RabbitMQ
# ------------------------------------------------
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URI=amqp://guest:guest@localhost:5672

# Queue names (don't change unless you know what you're doing)
RABBITMQ_QUEUE_SUMMARIZE=summarize.jobs
RABBITMQ_EXCHANGE_STATUS=video.status

# ------------------------------------------------
# Authentication (JWT)
# ------------------------------------------------
# IMPORTANT: Generate secure secrets for production!
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------
# API Service (vie-api)
# ------------------------------------------------
PORT=3000

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ------------------------------------------------
# Frontend (vie-web)
# ------------------------------------------------
FRONTEND_URL=http://localhost:5173

# Vite environment variables
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000/ws

# Production (update with your domain)
# VITE_API_URL=https://api.yourdomain.com/api
# VITE_WS_URL=wss://api.yourdomain.com/ws

# ------------------------------------------------
# Summarizer Service (vie-summarizer)
# ------------------------------------------------
SUMMARIZER_PORT=8000

# ------------------------------------------------
# Explainer Service (vie-explainer)
# ------------------------------------------------
EXPLAINER_PORT=8001

# ------------------------------------------------
# Anthropic Claude API
# ------------------------------------------------
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model to use for summarization and explanation
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Token limits
ANTHROPIC_MAX_TOKENS=4096

# ------------------------------------------------
# Future Services (not used in MVP)
# ------------------------------------------------

# Meilisearch (for full-text search)
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=your-meilisearch-key

# Qdrant (for vector search)
# QDRANT_HOST=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-key

# Redis (if needed for sessions/caching)
# REDIS_URL=redis://localhost:6379
