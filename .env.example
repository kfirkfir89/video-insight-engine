# ================================================
# Video Insight Engine - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values
# ================================================
CLAUDE_PROJECT_DIR="/path/to/your/video-insight-engine"

# ------------------------------------------------
# General
# ------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# ------------------------------------------------
# MongoDB
# ------------------------------------------------
# Development (no auth)
MONGODB_URI=mongodb://localhost:27017/video-insight-engine

# Production (with auth)
# MONGO_ROOT_USER=admin
# MONGO_ROOT_PASS=change-this-password

# ------------------------------------------------
# Authentication (JWT)
# ------------------------------------------------
# IMPORTANT: Generate secure secrets for production!
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------
# API Service (vie-api)
# ------------------------------------------------
PORT=3000

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Video creation daily limit (0 = unlimited, useful for dev/admin)
VIDEO_DAILY_LIMIT=10

# ------------------------------------------------
# Frontend & CORS
# ------------------------------------------------
FRONTEND_URL=http://localhost:5173

# Additional CORS origins (comma-separated, optional)
# Used for SSE endpoints that bypass Fastify's CORS plugin
# CORS_ADDITIONAL_ORIGINS=https://staging.yourdomain.com,https://preview.yourdomain.com

# Vite environment variables
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000/ws

# Debug WebSocket events (development only)
# VITE_DEBUG_WS=true

# Production (update with your domain)
# VITE_API_URL=https://api.yourdomain.com/api
# VITE_WS_URL=wss://api.yourdomain.com/ws

# ------------------------------------------------
# Internal Service URLs
# ------------------------------------------------
SUMMARIZER_URL=http://localhost:8000

# ------------------------------------------------
# Summarizer Service (vie-summarizer)
# ------------------------------------------------
SUMMARIZER_PORT=8000

# ------------------------------------------------
# Explainer Service (vie-explainer)
# ------------------------------------------------
EXPLAINER_PORT=8001

# Streaming configuration
# LLM_STREAM_MAX_WORKERS=10          # Max concurrent streaming requests
# LLM_STREAM_TOKEN_TIMEOUT_SECONDS=60 # Timeout waiting for next token

# ------------------------------------------------
# LLM Provider Configuration (Multi-Provider)
# ------------------------------------------------
# Provider options: anthropic, openai, gemini
LLM_PROVIDER=anthropic
LLM_FAST_PROVIDER=openai
LLM_FALLBACK_PROVIDER=gemini

# Token limits
LLM_MAX_TOKENS=4096
LLM_FAST_MAX_TOKENS=2048

# Timeouts and retries
LLM_TIMEOUT_SECONDS=60.0
LLM_NUM_RETRIES=2

# Optional model overrides (uses provider defaults if not set)
# LLM_MODEL=anthropic/claude-sonnet-4-20250514
# LLM_FAST_MODEL=openai/gpt-4o-mini

# ------------------------------------------------
# Provider API Keys
# ------------------------------------------------
# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (https://platform.openai.com/)
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini (https://aistudio.google.com/)
GEMINI_API_KEY=your-gemini-api-key-here

# ------------------------------------------------
# YouTube Transcript Proxy (Webshare)
# ------------------------------------------------
# Get credentials from: https://www.webshare.io/
# Purchase "Residential" proxy package (NOT "Proxy Server" or "Static Residential")
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# ------------------------------------------------
# AWS S3 Configuration (Transcript Storage)
# ------------------------------------------------
# Free tier: 5GB storage, 20K GET, 2K PUT requests/month
# Create bucket at: https://s3.console.aws.amazon.com/
TRANSCRIPT_S3_BUCKET=vie-transcripts
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Optional: Use LocalStack for offline development
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test

# ------------------------------------------------
# Future Services (not used in MVP)
# ------------------------------------------------

# Meilisearch (for full-text search)
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=your-meilisearch-key

# Qdrant (for vector search)
# QDRANT_HOST=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-key

# Redis (if needed for sessions/caching)
# REDIS_URL=redis://localhost:6379
